{
  "data": {
    "show": {
      "type": "bool",
      "displayName": "Show"
    },
    "width": {
      "type": "numeric",
      "displayName": "Width"
    },
    "lineColor": {
      "type": "fill",
      "displayName": "Color"
    },
    "transparency": {
      "type": "numeric",
      "displayName": "Transparency"
    },
    "style": {
      "type": "enum",
      "values": [
        "solid",
        "dashed",
        "dotted",
        "custom"
      ],
      "displayName": "Line style"
    },
    "autoScale": {
      "type": "bool",
      "displayName": "Scale by width",
      "description": "Automatically adjust the spacing between dashes and dots based on line width."
    },
    "dashArray": {
      "type": "formatting",
      "displayName": "Dash array",
      "description": "Space-separated values for dash and gap lengths in pixels, repeating in sequence."
    },
    "dashCap": {
      "type": "enum",
      "values": [
        "none",
        "round",
        "square"
      ],
      "displayName": "Dash cap"
    },
    "displayName": {
      "type": "text",
      "displayName": "Name",
      "description": "Set trend line name"
    },
    "combineSeries": {
      "type": "bool",
      "displayName": "Combine series",
      "description": "Show one trend line per series or combine"
    },
    "useHighlightValues": {
      "type": "bool",
      "displayName": "Use highlight values",
      "description": "Use highlight values to calculate trend line"
    }
  }
}
